{
  "_version": "1.84.0",
  "sap.app": {
    "id": "idts.bugmanagementui",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.24.0",
      "toolsId": "af1ef238-7d20-428e-b297-5c10e4677116"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/bug/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "idts.bugmanagementui.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BugsList",
          "target": "BugsList"
        },
        {
          "pattern": "Bugs({key}):?query:",
          "name": "BugsObjectPage",
          "target": "BugsObjectPage"
        }
      ],
      "targets": {
        "BugsList": {
          "type": "Component",
          "id": "BugsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Bugs",
              "enhanceI18n": "i18n/i18n.properties",
              "variantManagement": "Page",
              "navigation": {
                "Bugs": {
                  "detail": {
                    "route": "BugsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "condensedTableLayout": true,
                    "personalization": {
                      "column": true,
                      "sort": true,
                      "filter": true
                    },
                    "creationMode": {
                      "name": "CreationDialog",
                      "creationFields": "com.sap.vocabularies.UI.v1.FieldGroup#CreateBug"
                    },
                    "selectionMode": "Multi"
                  }
                }
              }
            }
          }
        },
        "BugsObjectPage": {
          "type": "Component",
          "id": "BugsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "enhanceI18n": "i18n/i18n.properties",
              "contextPath": "/Bugs"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
